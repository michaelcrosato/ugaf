{
  "name": "loom-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LOOM — a deterministic, prose-first text-game engine. Flagship world: The Hush.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hush": "src/cli/main.ts"
  },
  "scripts": {
    "play": "tsx src/cli/main.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "boundaries": "tsx scripts/check-boundaries.ts",
    "integrity": "tsx scripts/verify-integrity.ts",
    "coverage-report": "tsx scripts/coverage-report.ts",
    "golden": "tsx scripts/golden-tape.ts",
    "coherence": "tsx scripts/coherence-pass.ts",
    "playtest": "tsx scripts/playtest.ts",
    "swarm": "tsx scripts/blind-swarm.ts",
    "feedback": "tsx scripts/compile-feedback.ts",
    "flywheel": "tsx scripts/flywheel.ts",
    "gate": "tsx scripts/gate.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.8.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
